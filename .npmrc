# @pinta-ai/core is a PRIVATE GitHub Packages dependency. Its GitHub Packages
# URL is pinned in package-lock.json (no @pinta-ai scope redirect here, so this
# adapter's own @pinta-ai/* name still resolves to npmjs for publish/view).
# These lines provide registry auth in CI; core is bundled into dist/ at build.
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
